# ---------------------------------------------------------------------------
#  claude-trading-bot — example environment
#
#  EVERY VARIABLE BELOW IS OPTIONAL.
#
#  You do not need any of them to run `make demo`, `make test`, or any of the
#  reader-facing commands. The repo is offline-first: with no .env at all, it
#  serves deterministic synthetic fixtures and every script still runs.
#
#  Copy to `.env` ONLY when you want to point the code at the live APIs:
#      cp .env.example .env
#      # fill in the keys you actually have
#      CTB_OFFLINE=0 python screener/screener.py
#
#  .env is gitignored. Never commit it. Never paste a key into a chat.
# ---------------------------------------------------------------------------

# The offline switch. Default is 1 (offline). Set to 0 to use the live READ APIs.
# This is a DATA switch, not a MONEY switch: it does NOT enable live trading.
# Live trading needs a code-level opt-in — see docs/08-going-live.md.
CTB_OFFLINE=1

# Anthropic — console.anthropic.com. Unlocks: the live Messages API.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Unusual Whales — unusualwhales.com/public-api. Unlocks: live options flow.
# Paid tier required. Trial is $50/week and is the cheapest tier with API access
# at all; the free "Free Shamu" web tier does NOT include the API.
UW_API_KEY=your-uw-key-here

# Alpaca — alpaca.markets. Unlocks: paper trading against a real broker.
# Paper and live key pairs are DIFFERENT. Don't mix them.
ALPACA_API_KEY=your-alpaca-key-id
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live URL (Chapter 10, Phase 2): https://api.alpaca.markets
# Changing this line alone does NOT enable live trading. It cannot.

# Kalshi — kalshi.com. Unlocks: signed requests to the Kalshi API.
# Download the private key immediately when you create the pair — Kalshi cannot
# retrieve it later. Never commit the PEM.
KALSHI_KEY_ID=your-kalshi-key-id-uuid
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi-private-key.pem
